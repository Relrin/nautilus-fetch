    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "cronstrue": "3.24.0",
    "lucide-react": "1.25.0",
    "radix-ui": "1.6.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.3",
    "@tanstack/react-query-devtools": "5.101.3",
    "@types/node": "26.1.1",
