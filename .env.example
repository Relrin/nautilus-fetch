# Copy to .env and adjust. All values shown are defaults used by docker-compose.

# IB Gateway connection (container name on the same Docker network, or host IP)
IB_HOST=host.docker.internal
IB_PORT=4002            # 4002 = paper gateway, 4001 = live gateway
IB_CLIENT_ID=17         # must be unique per client on the same gateway

# Host directories mapped into the container
STATE_DIR=./deploy-data/state
CATALOG_DIR=./deploy-data/catalog

# Unraid example
# STATE_DIR=/mnt/user/appdata/nautilus-fetch/state
# CATALOG_DIR=/mnt/user/data/catalog

# State database. Default is SQLite; PostgreSQL is also supported.
DATABASE_URL=sqlite+aiosqlite:////data/state/nautilus-fetch.sqlite
# DATABASE_URL=postgresql+asyncpg://nautilus:nautilus@postgres:5432/nautilus_fetch

TZ=UTC
